# 本地开发：复制成仓库根的 `.env`（已 gitignore）。
# 部署 Render：这些在「后端服务 → Environment」里设；VITE_API_BASE 由 render.yaml 注入，不用手填。
# DeepSeek（OpenAI 兼容）。flash=deepseek-chat（默认）；pro=deepseek-reasoner
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 后端端口
PORT=8787
# 前端访问后端的地址（dev）
VITE_API_BASE=http://localhost:8787
